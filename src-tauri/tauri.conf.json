{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenAnime",
  "version": "1.0.2",
  "identifier": "com.openanime.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bunx svelte-kit sync && bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Turkish"],
        "template": "./nsis/installer.nsi",
        "installerIcon": "icons/icon.ico",
        "headerImage": "nsis/images/header.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGM0I5RUI5NEU5ODYzMUEKUldRYVk1aE91WjQ3YnptNm12QUJjMjM2ZlFhODB2bk02Mk9yZElYaktDbkpUcEtGWW1lNkJjUVQK",
      "endpoints": [
        "https://github.com/Dark-Hunter-TR/OpenAnime-Desktops/releases/latest/download/latest.json"
      ]
    }
  }
}

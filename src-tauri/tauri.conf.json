{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenAnime",
  "version": "1.0.2-beta-02",
  "identifier": "com.darkhunter.openanime-desktops",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bunx svelte-kit sync && bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Turkish"],
        "template": "./nsis/installer.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwNjMxODk2QTdEQjVEQzgKUldUSVhkdW5saGhqb1BtZU9IQ2VkN3V1dUQ3bVFRTDhkV0YzYlVPY09JZXF1cHlmWjg1UkJlVTYK",
      "endpoints": [
        "https://github.com/Dark-Hunter-TR/OpenAnime-Desktops/releases/latest/download/latest.json"
      ]
    }
  }
}
